---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

// ข้อมูลสินค้า (คืนค่าข้อความเดิมของพี่ทั้งหมด ห้ามแตะต้อง)
const products = [
  {
    title: 'KU72-CORN',
    alt1 : 'เครื่องวัดความชื้นข้าวโพด KU72-CORN',
    subtitle: 'วัดความชื้นข้าวโพด</br>เพื่อซื้อ-ขายข้าวโพดตามกฏหมาย',
    description: '',
    image: '~/assets/images/KU72-CORN01.jpg',
    link: '/Products/corn-moisture-meter-ku72/',
    features: [ 'มีตรารับรอง สำนักชั่งตวงวัด*', 'ใช้ซื้อ-ขายข้าวโพดตามกฏหมาย', 'วัดความชื้นได้ไม่เกิน 35% ตามข้อกำหนดในประกาศกรมการค้าภายใน' ,],
  },
  {
    title: 'KU60',
    alt1 : 'เครื่องวัดความชื้นข้าวโพด KU60',
    subtitle: 'วัดความชื้นข้าวโพด</br>และเมล็ดธัญพืช',
    description: '',
    image: '~/assets/images/KU60-01.jpg',
    link: '/Products/grain-moisture-meter-ku60/',
    features: ['วัดความชื้นได้ 5 ชนิดเมล็ด</br><strong class="text-amber-600 font-bold">•เมล็ดข้าวโพด</strong></br>• ถั่วเขียว</br>• ถั่วเหลือง</br>• ข้าวฟ่าง</br>• ข้าวเปลือก', 'หรือสั่งผลิตเลือกชนิดเมล็ดตามที่ผู้ซื้อต้องการ ได้สูงสุด 7 ชนิด'],
  },
  {
    title: 'EE-KU',
    alt1 : 'เครื่องวัดความชื้นข้าวโพด EE-KU',
    subtitle: `วัดความชื้นข้าวโพด</br>รุ่นประหยัด ยอดนิยม`,
    description: '',
    image: '~/assets/images/EEKU-01.jpg', 
    link: '/Products/grain-moisture-meter-eeku/',
    features: ['วัดความชื้นข้าวโพด','สามารถวัดความชื้นเกิน 35%','ใช้งานง่าย', 'ราคาประหยัด'],
  },
];
---
<WidgetWrapper id="Cornproducts" isDark={false} containerClass="max-w-7xl mx-auto px-4 sm:px-6" bg='<div class="absolute inset-0 bg-white dark:bg-transparent"></div>'>
  
  <Headline
    title="เครื่องวัดความชื้นข้าวโพด"
    tagline="Corn moisture meter"
    subtitle="มีให้เลือก 3 รุ่นตามการใช้งาน"
    classes={{ container: 'max-w-xl sm:mx-auto lg:max-w-2xl mb-8 md:mb-12', title: 'text-2xl md:text-4xl font-bold' }}
  />

  <div class="grid gap-8 md:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
    {products.map((product) => (
      <a 
        href={product.link} 
        class="group flex flex-col justify-between rounded-2xl bg-white dark:bg-slate-900 shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 dark:border-gray-800"
      >
        
        {/* รูปภาพปรับขนาดให้สวยบนมือถือ */}
        <div class="relative aspect-video sm:aspect-square md:aspect-video overflow-hidden">
             <Image
                src={product.image}
                alt={product.alt1}
                class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-110"
                format="webp" 
                widths={[400, 800]} 
                sizes="(max-width: 767px) 100vw, 25vw"
                width={400} 
                height={300}
              />
              <div class="absolute top-3 right-3 bg-primary text-white text-[16px] font-bold px-2 py-1 rounded-full shadow-sm">
                {product.title}
              </div>
        </div>

        <div class="p-5 flex-1 flex flex-col">
            <div class="mb-3">
                <h3 class="text-4xl font-bold leading-tight text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                  รุ่น {product.title}
                </h3>
                <p class="text-lg text-primary font-bold tracking-wide uppercase" set:html={product.subtitle}>
            </div>
            
            {/* คำอธิบายยาวๆ ของพี่แสดงครบถ้วน 100% */}
            <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                {product.description}
            </p>

            {/* รายการจุดเด่นของพี่แสดงครบถ้วน 100% */}
            <ul class="text-lg text-gray-500 mb-6 space-y-2">
                {product.features.map(f => (
                    <li class="flex items-start">
                        <svg class="w-4 h-4 text-green-500 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                        <span class="leading-tight" set:html={f} />
                    </li>
                ))}
            </ul>

            <div class="mt-auto">
                <div class="w-full bg-primary text-white text-center py-3 rounded-xl font-bold text-sm group-hover:bg-primary-dark transition-colors">
                  ดูรายละเอียดสินค้า
                </div>
            </div>
        </div>
      </a>
    ))}
  </div>

  {/* ส่วนหมายเหตุของพี่แสดงครบถ้วน 100% */}
  <div class="mt-16 mx-auto max-w-5xl">
    <div class="rounded-2xl bg-slate-50 dark:bg-slate-800/50 p-6 md:p-10 border border-slate-100 dark:border-slate-700">
      <div class="flex items-center gap-3 mb-6">
          <div class="p-2 bg-primary/10 rounded-lg text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M3 12h1m8 -9v1m8 8h1m-15.4 -6.4l.7 .7m12.1 -.7l-.7 .7"></path><path d="M9 16a5 5 0 1 1 6 0a3.5 3.5 0 0 0 -1 3a2 2 0 0 1 -4 0a3.5 3.5 0 0 0 -1 -3"></path><path d="M9.7 17l4.6 0"></path></svg>
          </div>
          <h4 class="text-xl font-bold text-gray-900 dark:text-white">หมายเหตุ</h4>
      </div>
        
      <ul class="grid md:grid-cols-1 gap-6 text-sm text-gray-600 dark:text-slate-400">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">*</span>
          <span><strong>มีตราแสดงการตรวจรับรอง* : </strong> ตรวจรับรองโดยสำนักงานกลางชั่งตวงวัด กรมการค้าภายใน กระทรวงพาณิชย์ ตาม พระราชบัญญัติมาตราชั่งตวงวัด พ.ศ.2542</span>
        </li>
      </ul>
      
      <div class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-700 text-center md:text-left">
         <p class="text-sm text-slate-500 italic">
           สงสัยเพิ่มเติม? <a href="https://line.me/ti/p/~@grainsure" class="text-primary hover:underline font-bold" data-astro-reload>คุยกับทีมงานทาง Line คลิก</a>
         </p>
      </div>
    </div>
  </div>
    <div class="py-2 md:py-2 flex flex-col justify-center text-center px-4">
      <!-- <h3 class="text-xl md:text-2xl font-bold mb-6 text-slate-800">ดาวน์โหลดคู่มือใช้งาน</h3> -->
      <a 
        href="/manual/" 
        class="inline-flex items-center self-center px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-bold text-white bg-gradient-to-r from-red-400 to-red-800 rounded-full shadow-xl hover:-translate-y-1 active:scale-95 transition-all group"
      >
        คลิกดาวน์โหลดคู่มือใช้งาน
        <svg class="w-5 h-5 md:w-6 md:h-6 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </a>
    </div>  
</WidgetWrapper>