---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
const { image } = Astro.props;

import Image from '~/components/common/Image.astro'; // เรียกใช้ Component รูปภาพ
import heroBg from '~/assets/images/gs-bg1.jpg'; // รูป PC
import heroBgMobile from '~/assets/images/gs-bg3.jpg'; // รูปมือถือ

import Hero from '~/components/widgets/Hero3.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import GSCalculator from '~/components/widgets/GS-Calculator.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Content2 from '~/components/widgets/Content2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import MyProductList from '~/components/widgets/MyProductList.astro';
import GSImageGrid from '~/components/widgets/GS-ImageGrid.astro';
import gsCalImg from '~/assets/images/GScal.jpg';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks'; // 1. Import ตัวช่วยสร้างลิงก์
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

// 1. ดึงบทความทั้งหมดจากโฟลเดอร์ post
const allPosts = await getCollection('post');

// 2. ดึงบทความเด่น 4 อันแรก (เรียงตาม priority ที่ตั้งไว้ใน MDX)[cite: 7]
const featuredPosts = allPosts
  .filter((post) => post.data.isFeatured)
  .sort((a, b) => (a.data.priority || 99) - (b.data.priority || 99))
  .slice(0, 4);

// 3. ดึงบทความล่าสุด 4 อัน (กรองตัวที่ซ้ำกับบทความเด่นออก)[cite: 7]
const latestPosts = allPosts
  .filter((post) => !featuredPosts.some((f) => f.id === post.id))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);

// 4. จัดรูปแบบข้อมูลใหม่ (Mapping) เพื่อให้ Widget และ URL ทำงานถูกต้อง[cite: 8, 10]
const postsToDisplay = [...latestPosts , ...featuredPosts].map((post) => {
  // ลบนามสกุลไฟล์ (.mdx) ออกจาก id เพื่อใช้เป็น slug
  const slug = post.id.replace(/\.[^/.]+$/, ""); 
  
  return {
    ...post,
    ...post.data,
    // สร้างลิงก์ตามรูปแบบ: /หมวดหมู่/ชื่อบทความ ตามที่ตั้งไว้ใน config
    permalink: getPermalink(`${post.data.category}/${slug}`, 'post'), 
  };
});

// ส่วนสำหรับตรวจสอบข้อมูลในหน้าจอ Terminal[cite: 7]
console.log('--- Debugging Grainsure Blog ---');
console.log('บทความทั้งหมด:', allPosts.length);
console.log('บทความเด่นที่หาเจอ:', featuredPosts.length);
console.log('รายชื่อบทความที่จะแสดง:', postsToDisplay.map(p => p.data.title));

// 5. ดึง Tag ทั้งหมดจากบทความที่มี และทำให้ไม่ซ้ำกัน (Unique Tags)[cite: 2, 7]
//const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
// --- ส่วน Logic ใน index.astro ---

// 1. กำหนดลำดับ Tag ที่ต้องการให้เรียง (อันไหนขึ้นก่อนใส่ก่อน)
const tagOrder = [
  'grain moisture tool เครื่องวัดความชื้น',
  'grainsure EE-KU',
  'grainsure KU-60',
  'grainsure KU-72-CORN',
  'grainsure KU-72-PADDY',
  'moisture content ความชื้นเมล็ด',
  'maize ข้าวโพด',
  'paddy ข้าว', // <--- ย้ายมาอยู่ใกล้ข้าวโพดแล้วครับ
  'jagung',
  'beras padi',
  'DIT announcement กฎหมายชั่งตวงวัด'
];

// 2. ดึง Tag ทั้งหมดมาแล้วเรียงตามรายการข้างบน[cite: 7, 9]
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))]
  .sort((a, b) => {
    const indexA = tagOrder.indexOf(a);
    const indexB = tagOrder.indexOf(b);
    
    // ถ้า Tag ไหนไม่ได้ระบุในลิสต์ ให้เอาไปไว้ท้ายสุด
    if (indexA === -1 && indexB === -1) return 0;
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;
    
    return indexA - indexB;
  });
// --- Debug Tag ---
console.log('Tags ที่หาเจอ:', allTags);

const metadata = {
  title: 'Grainsure: เครื่องวัดความชื้นเมล็ดพืช ข้าว ข้าวโพด กาแฟ เม็ดผัก(Grain Moisture Meter) รุ่น KU72 KU60 EE-KU | Alat Ukur Kadar Air | Grainsure',
