---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { getEntry } from 'astro:content'; // 1. เพิ่มการดึงข้อมูลจาก Collection

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// 2. ดึงข้อมูลจาก src/content/category/all-topic.json
const articleEntry = await getEntry('category', 'all-topic');
const articleData = articleEntry?.data;

// 2. เพิ่มส่วน Debug เพื่อดูค่าใน Terminal
console.log('--- DEBUG: Article Metadata ---');
console.log('File Found:', articleEntry ? 'Yes' : 'No');
console.log('Title from JSON:', articleData?.title);
console.log('Description from JSON:', articleData?.description);
console.log('-------------------------------');

const metadata = {
  // 3. ใช้ title และ description จาก JSON ถ้าไม่มีให้ใช้ค่าเดิมสำรองไว้
  title: `${articleData?.title || 'Blog'}${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  description: articleData?.description || "เจาะลึกเทคโนโลยีการวัดความชื้นและเทคนิคการจัดการเมล็ดพันธุ์",
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
    description: articleData?.description,
  },
};
---

<Layout metadata={metadata}>
<section class="relative px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-7xl overflow-hidden">
  <!-- ส่วนพื้นหลังคงเดิม -->
  <div class="absolute inset-0 bg-blue-50 dark:bg-slate-900 pointer-events-none -z-10" aria-hidden="true"></div>
  
  <div class="relative max-w-4xl mx-auto">
    <Headline
      // 4. ดึงคำบรรยายจาก JSON มาแสดงใน Subtitle (ถ้ามี)
      subtitle={articleData?.description || "เจาะลึกเทคโนโลยีการวัดความชื้นและเทคนิคการจัดการเมล็ดพันธุ์..."}
    >
      <span class="text-accent dark:text-white highlight">
        {articleData?.title || "Grainsure Insights"}
      </span>
      <br />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-blue-600 font-extrabold">
        คลังความรู้เพื่อเกษตรกรไทย
      </span>
    </Headline>

    <div class="mt-8">
      <BlogList posts={page.data} />
    </div>

    <div class="mt-10 border-t border-gray-200 dark:border-slate-700 pt-8">
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </div>
</section>
</Layout>